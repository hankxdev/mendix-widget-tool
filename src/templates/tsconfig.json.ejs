{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "./"
    },
    "include": ["./src", "./typings"<% if (mode === 'workspace') { %>, "../../packages/shared-typings"<% } %>],
    "exclude": ["node_modules", "dist", "__tests__"]
}
